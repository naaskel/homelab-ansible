services:
  nginx-proxy-manager:
    image: jc21/nginx-proxy-manager:latest
    container_name: nginx-proxy-manager
    restart: unless-stopped
    ports:
      - "80:80/tcp"
      - "443:443/tcp"
      - "81:81/tcp"
    volumes:
      - /home/{{ ansible_user }}/ssd/nginx-proxy-manager/data:/data
      - /home/{{ ansible_user }}/ssd/nginx-proxy-manager/letsencrypt:/etc/letsencrypt
    networks:
      - homelab

networks:
  homelab:
    external: true
